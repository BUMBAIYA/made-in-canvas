#!/bin/sh

echo "Running pre-commit checks..."

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
echo "Staged files:"
echo "$STAGED_FILES" | sed 's/^/  /'

if [ -z "$STAGED_FILES" ]; then
  echo "No staged files to process"
  exit 0
fi
echo ""

# Format all staged files
echo "Running Prettier..."
if [ -n "$STAGED_FILES" ]; then
  echo "$STAGED_FILES" | xargs pnpm exec prettier --write --ignore-unknown
  echo "  Prettier completed"
else
  echo "  No files to format"
fi
echo ""

# lint only JS/TS files
echo "Running ESLint..."
ESLINT_FILES=$(echo "$STAGED_FILES" | grep -E '\.(js|ts|tsx)$')
if [ -n "$ESLINT_FILES" ]; then
  echo "  Linting files:"
  echo "$ESLINT_FILES" | sed 's/^/    /'
  echo "$ESLINT_FILES" | xargs pnpm exec eslint --fix
  echo "  ESLint completed"
else
  echo "  No JS/TS files to lint"
fi
echo ""

# Add the formatted files back to the index
echo "Updating git index..."
git update-index --again

echo "Pre-commit checks completed successfully!"
